{
  "name": "dollops-admin",
  "version": "1.1.1",
  "description": "Dollops Ice Cream — Admin Management System",
  "author": {
    "name": "Ross Mackenzie",
    "email": "ross@dollopsicecream.uk"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "uk.dollopsicecream.admin",
    "productName": "Dollops Admin",
    "copyright": "© 2025 Ross Mackenzie — Dollops Ice Cream",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "Ross Mackenzie"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": null
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "bobchomp",
      "repo": "dollops-admin-releases",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "firebase": "^10.7.0"
  }
}